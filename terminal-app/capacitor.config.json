{
    "appId": "com.smartdoor.terminal",
    "appName": "AuraLock Terminal",
    "webDir": "dist",
    "server": {
        "androidScheme": "http",
        "cleartext": true,
        "hostname": "localhost",
        "allowNavigation": [
            "192.168.2.165:8000"
        ]
    },
    "android": {
        "allowMixedContent": true,
        "backgroundColor": "#0a0f1e",
        "overrideUserAgent": "AuraLock-Terminal/1.0"
    },
    "plugins": {
        "NativeBiometric": {
            "reason": "Verify identity for attendance"
        },
        "Camera": {
            "permissions": [
                "camera"
            ]
        }
    }
}
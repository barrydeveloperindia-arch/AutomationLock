{
    "appId": "com.smartlock.terminal",
    "appName": "Smart Lock Terminal",
    "webDir": "dist",
    "server": {
        "androidScheme": "https"
    },
    "android": {
        "allowMixedContent": true,
        "backgroundColor": "#0a0f1e",
        "overrideUserAgent": "AuraLock-Terminal/1.0"
    },
    "plugins": {
        "NativeBiometric": {
            "reason": "Verify identity for attendance"
        },
        "Camera": {
            "permissions": [
                "camera"
            ]
        }
    }
}